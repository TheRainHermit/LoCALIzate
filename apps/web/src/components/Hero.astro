---
const { title = "CaliGuía: El Asistente Turístico Inteligente", subtitle = "La ciudad te habla, te guía y te sorprende con sabor local." } = Astro.props;
---

<section class="relative py-20 px-4 bg-gradient-to-b from-surface-container-highest to-surface-container flex flex-col items-center justify-center text-center overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-10" style="background-image: radial-gradient(#ffb300 1.5px, transparent 1.5px), radial-gradient(#bb0020 1.5px, #fff8f3 1.5px); background-size: 40px 40px; background-position: 0 0, 20px 20px;"></div>
  <h1 class="text-4xl md:text-5xl font-extrabold text-primary mb-4 leading-tight drop-shadow-lg z-10">
    {title}
  </h1>
  <p class="text-lg md:text-2xl text-on-surface-variant mb-8 max-w-2xl mx-auto z-10">
    {subtitle}
  </p>
  <a href="#features" class="inline-block px-8 py-3 rounded-full bg-primary text-white font-semibold text-lg shadow-lg hover:bg-primary-container transition z-10">
    Descubre cómo funciona
  </a>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[120vw] h-32 bg-gradient-to-t from-surface-container-highest to-transparent pointer-events-none"></div>
</section>