---
import Card from './ui/Card.astro';
import ThemedText from './ui/ThemedText.astro';
import Badge from './ui/Badge.astro';

interface Evento {
  id?: string;
  nombre: string;
  fecha_inicio: string;
  imagen_principal?: string;
  descripcion_corta?: string;
  ubicacion?: string;
}

interface Props {
  title?: string;
  eventos?: Evento[];
}

const {
  title = "Próximos eventos",
  eventos = [],
} = Astro.props;

const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
};
---

<section class="events-carousel">
  <div class="container">
    <ThemedText variant="headline-md" class="carousel-title">
      {title}
    </ThemedText>

    {
      eventos.length === 0 ? (
        <ThemedText variant="body-md" color="muted" center class="empty-state">
          No hay eventos próximos. ¡Vuelve pronto!
        </ThemedText>
      ) : (
        <div class="carousel-wrapper">
          <div class="carousel">
            {eventos.map((evento) => (
              <Card
                variant="elevated"
                padding="md"
                class="carousel-card"
              >
                <a
                  href={`/evento/${evento.id || evento.nombre}`}
                  class="carousel-card-link"
                >
                  {evento.imagen_principal && (
                    <div class="carousel-image">
                      <img
                        src={evento.imagen_principal}
                        alt={evento.nombre}
                        loading="lazy"
                      />
                    </div>
                  )}

                  <div class="carousel-content">
                    <ThemedText variant="title-md" as="h3">
                      {evento.nombre}
                    </ThemedText>

                    <div class="carousel-meta">
                      <Badge color="secondary" size="sm">
                        📅 {formatDate(evento.fecha_inicio)}
                      </Badge>
                      {evento.ubicacion && (
                        <Badge color="tertiary" size="sm">
                          📍 {evento.ubicacion}
                        </Badge>
                      )}
                    </div>

                    {evento.descripcion_corta && (
                      <ThemedText
                        variant="body-sm"
                        color="muted"
                        class="carousel-desc"
                      >
                        {evento.descripcion_corta}
                      </ThemedText>
                    )}
                  </div>
                </a>
              </Card>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .events-carousel {
    padding: var(--space-xxl) 0;
    background-color: var(--color-surface);
  }

  .carousel-title {
    margin: 0 0 var(--space-xl) 0;
    color: var(--color-primary);
  }

  .carousel-wrapper {
    position: relative;
    overflow: hidden;
  }

  .carousel {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-behavior: smooth;
    padding-bottom: var(--space-md);
    scroll-padding: var(--space-lg);
  }

  .carousel::-webkit-scrollbar {
    height: 6px;
  }

  .carousel::-webkit-scrollbar-track {
    background-color: var(--color-surface-container);
    border-radius: 3px;
  }

  .carousel::-webkit-scrollbar-thumb {
    background-color: var(--color-outline-variant);
    border-radius: 3px;
  }

  .carousel::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-outline);
  }

  .carousel-card {
    flex-shrink: 0;
    width: 100%;
    max-width: 300px;
    min-height: 320px;
    overflow: hidden;
    transition: all var(--transition-normal);
  }

  .carousel-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .carousel-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .carousel-image {
    width: 100%;
    height: 140px;
    overflow: hidden;
    background-color: var(--color-surface-container);
    margin-bottom: var(--space-md);
    border-radius: var(--radius-md);
  }

  .carousel-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .carousel-card:hover .carousel-image img {
    transform: scale(1.05);
  }

  .carousel-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .carousel-content h3 {
    margin: 0;
  }

  .carousel-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .carousel-desc {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .empty-state {
    margin: var(--space-xl) 0;
    padding: var(--space-xl);
    text-align: center;
  }

  @media (max-width: 768px) {
    .carousel-card {
      max-width: 260px;
      min-height: 300px;
    }

    .carousel {
      gap: var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .carousel {
      gap: var(--space-sm);
    }

    .carousel-card {
      max-width: calc(100vw - 40px);
    }
  }
</style>