---
/**
 * AdminTable.astro
 * Props:
 * - columns: string[] (nombres de columnas)
 * - data: any[] (arreglo de objetos, cada uno es una fila)
 * - actions?: (fila: any) => AstroComponent[] (opcional, para botones de acción)
 */
const { columns = [], data = [], actions } = Astro.props;
---

<table class="min-w-full divide-y divide-outline-variant bg-surface rounded-lg shadow">
  <thead class="bg-surface-container-high">
    <tr>
      {columns.map(col => (
        <th class="px-4 py-2 text-left text-xs font-semibold text-on-surface uppercase tracking-wider">{col}</th>
      ))}
      {actions && <th class="px-4 py-2"></th>}
    </tr>
  </thead>
  <tbody class="divide-y divide-outline-variant">
    {data.length === 0 ? (
      <tr>
        <td class="px-4 py-4 text-center text-on-surface-variant" colSpan={columns.length + (actions ? 1 : 0)}>
          Sin datos para mostrar
        </td>
      </tr>
    ) : (
      data.map((row, idx) => (
        <tr class="hover:bg-surface-container-low" key={idx}>
          {columns.map(col => (
            <td class="px-4 py-2 text-on-surface">{row[col] ?? '-'}</td>
          ))}
          {actions && (
            <td class="px-4 py-2 flex gap-2">
              {actions(row)}
            </td>
          )}
        </tr>
      ))
    )}
  </tbody>
</table>