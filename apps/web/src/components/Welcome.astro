---
import Button from './ui/Button.astro';
import ThemedText from './ui/ThemedText.astro';
import Card from './ui/Card.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title = "Bienvenido a LoCALIzate",
  subtitle = "La aplicación que te conecta con el corazón de Cali",
  ctaText = "Explorar ahora",
  ctaHref = "/explorador",
} = Astro.props;
---

<section class="welcome">
  <div class="welcome-content container">
    <div class="welcome-text">
      <ThemedText variant="headline-lg">
        {title}
      </ThemedText>
      <ThemedText variant="body-lg" color="muted" class="welcome-subtitle">
        {subtitle}
      </ThemedText>
      <Button label={ctaText} href={ctaHref} size="lg" />
    </div>

    <div class="welcome-visual">
      <Card variant="filled" padding="xl" class="welcome-card">
        <div class="welcome-icon">🌿</div>
        <ThemedText variant="title-md" center>
          Descubre Cali
        </ThemedText>
        <ThemedText variant="body-sm" color="muted" center>
          Con experiencias personalizadas basadas en IA
        </ThemedText>
      </Card>
    </div>
  </div>
</section>

<style>
  .welcome {
    padding: var(--space-xxl) 0;
    background: linear-gradient(
      135deg,
      var(--color-surface-container),
      var(--color-surface)
    );
  }

  .welcome-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .welcome-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .welcome-text h1 {
    margin: 0;
  }

  .welcome-subtitle {
    margin: 0;
    line-height: 1.6;
  }

  .welcome-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .welcome-card {
    text-align: center;
    max-width: 300px;
  }

  .welcome-icon {
    font-size: 72px;
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .welcome-card h3 {
    margin: 0;
  }

  .welcome-card p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .welcome {
      padding: var(--space-xl) 0;
    }

    .welcome-content {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .welcome-icon {
      font-size: 56px;
    }
  }
</style>