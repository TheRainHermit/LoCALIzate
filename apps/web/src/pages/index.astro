---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/ui/NavBar.astro';
import Footer from '../components/ui/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Welcome from '../components/Welcome.astro';
import EventsCarousel from '../components/EventsCarousel.astro';

const eventos = [
  {
    id: '1',
    nombre: 'Festival de Salsa 2026',
    fecha_inicio: '2026-06-15',
    imagen_principal: 'https://via.placeholder.com/400x200?text=Festival+Salsa',
    descripcion_corta: 'Vive la mejor música y danza caleña en el corazón de la ciudad.',
    ubicacion: 'Parque Belalcázar',
  },
  {
    id: '2',
    nombre: 'Feria Gastronómica del Pacífico',
    fecha_inicio: '2026-07-10',
    imagen_principal: 'https://via.placeholder.com/400x200?text=Gastronomia',
    descripcion_corta: 'Prueba los mejores platillos de la cocina caleña y del Pacífico.',
    ubicacion: 'Centro Comercial',
  },
  {
    id: '3',
    nombre: 'Concierto Artistas Locales',
    fecha_inicio: '2026-08-05',
    imagen_principal: 'https://via.placeholder.com/400x200?text=Concierto',
    descripcion_corta: 'Apoya a los talentos musicales emergentes de Cali.',
    ubicacion: 'Teatro Municipal',
  },
];
---

<Layout title="LoCALIzate - Descubre Cali">
  <NavBar />
  
  <main>
    <Hero
      title="CaliGuía: Tu Asistente Turístico Inteligente"
      subtitle="Descubre los secretos, sabores y ritmos de Cali con experiencias personalizadas"
    />

    <Features />

    <Welcome
      title="Comienza tu aventura"
      subtitle="Accede a mapas interactivos, guías de audio y recomendaciones personalizadas"
      ctaText="Ir al Explorador"
      ctaHref="/explorador"
    />

    <EventsCarousel {eventos} />
  </main>

  <Footer />
</Layout>