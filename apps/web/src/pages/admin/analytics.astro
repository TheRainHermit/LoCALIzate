---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Simulación de métricas (en un futuro, consulta tu API)
const stats = {
  lugares: 24,
  eventos: 12,
  usuarios: 320,
  visitas: 1540,
  ratingPromedio: 4.7,
};
---

<AdminLayout>
  <h1 class="text-2xl font-bold mb-6 text-primary">Analytics</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-10">
    <div class="bg-surface rounded-xl shadow p-6 flex flex-col items-center">
      <span class="text-3xl mb-2">📍</span>
      <div class="text-lg font-semibold">{stats.lugares}</div>
      <div class="text-on-surface-variant text-sm">Lugares</div>
    </div>
    <div class="bg-surface rounded-xl shadow p-6 flex flex-col items-center">
      <span class="text-3xl mb-2">🎉</span>
      <div class="text-lg font-semibold">{stats.eventos}</div>
      <div class="text-on-surface-variant text-sm">Eventos</div>
    </div>
    <div class="bg-surface rounded-xl shadow p-6 flex flex-col items-center">
      <span class="text-3xl mb-2">👥</span>
      <div class="text-lg font-semibold">{stats.usuarios}</div>
      <div class="text-on-surface-variant text-sm">Usuarios</div>
    </div>
    <div class="bg-surface rounded-xl shadow p-6 flex flex-col items-center">
      <span class="text-3xl mb-2">👁️</span>
      <div class="text-lg font-semibold">{stats.visitas}</div>
      <div class="text-on-surface-variant text-sm">Visitas mensuales</div>
    </div>
    <div class="bg-surface rounded-xl shadow p-6 flex flex-col items-center">
      <span class="text-3xl mb-2">⭐</span>
      <div class="text-lg font-semibold">{stats.ratingPromedio}</div>
      <div class="text-on-surface-variant text-sm">Rating promedio</div>
    </div>
  </div>

  <div class="bg-surface-container-high rounded-xl shadow p-8 mt-8 flex flex-col items-center">
    <span class="text-xl text-on-surface-variant mb-2">Próximamente:</span>
    <span class="text-2xl font-bold text-primary">Gráficas de uso y mapas de calor</span>
    <div class="mt-4 text-on-surface-variant text-center">
      Aquí podrás visualizar el flujo de turistas, eventos más populares y zonas con mayor actividad.
    </div>
  </div>
</AdminLayout>