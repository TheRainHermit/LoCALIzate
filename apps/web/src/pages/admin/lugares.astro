---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminTable from '../../components/AdminTable.astro';

// Simulación de lugares (en el futuro, consulta tu API)
const lugares = [
  { nombre: "Iglesia La Ermita", zona: "centro", categoria: "cultura", rating: 4.9 },
  { nombre: "El Gato del Río", zona: "oeste", categoria: "arte", rating: 4.8 },
  { nombre: "Cristo Rey", zona: "oeste", categoria: "historia", rating: 4.7 },
];
---

<AdminLayout>
  <h1 class="text-2xl font-bold mb-6 text-primary">Lugares turísticos</h1>

  <form class="bg-surface rounded-xl shadow p-6 flex flex-col gap-4 max-w-xl mb-10">
    <h2 class="text-lg font-semibold mb-2 text-primary">Agregar nuevo lugar</h2>
    <input class="rounded border border-outline-variant p-2 bg-surface-container" placeholder="Nombre del lugar" />
    <input class="rounded border border-outline-variant p-2 bg-surface-container" placeholder="Zona" />
    <input class="rounded border border-outline-variant p-2 bg-surface-container" placeholder="Categoría" />
    <input class="rounded border border-outline-variant p-2 bg-surface-container" placeholder="Rating" />
    <button type="submit" class="mt-2 px-6 py-2 rounded-lg bg-primary text-white font-semibold shadow hover:bg-primary-container transition">
      Guardar lugar
    </button>
  </form>

  <h2 class="text-xl font-semibold mb-4 text-primary">Lista de lugares</h2>
  <AdminTable columns={["nombre", "zona", "categoria", "rating"]} data={lugares} />
</AdminLayout>