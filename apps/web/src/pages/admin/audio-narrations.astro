---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AudioRecorder from '../../components/AudioRecorder.astro';

// Simulación de lugares/eventos (en el futuro, consulta tu API)
const lugares = [
  { id: 1, nombre: "Iglesia La Ermita" },
  { id: 2, nombre: "El Gato del Río" },
  { id: 3, nombre: "Cristo Rey" },
];
---

<AdminLayout>
  <h1 class="text-2xl font-bold mb-6 text-primary">Narrativas de Audio</h1>
  <form class="bg-surface rounded-xl shadow p-6 flex flex-col gap-4 max-w-xl mx-auto">
    <label class="font-semibold text-on-surface">
      Lugar o evento:
      <select class="mt-1 block w-full rounded border border-outline-variant p-2 bg-surface-container">
        {lugares.map(lugar => (
          <option value={lugar.id}>{lugar.nombre}</option>
        ))}
      </select>
    </label>
    <label class="font-semibold text-on-surface">
      Narrativa (texto):
      <textarea class="mt-1 block w-full rounded border border-outline-variant p-2 bg-surface-container" rows="3" placeholder="Escribe aquí la narrativa caleña..."></textarea>
    </label>
    <div>
      <span class="font-semibold text-on-surface">Graba la narrativa en audio:</span>
      <AudioRecorder />
    </div>
    <button type="submit" class="mt-4 px-6 py-2 rounded-lg bg-primary text-white font-semibold shadow hover:bg-primary-container transition">
      Guardar narrativa
    </button>
  </form>
</AdminLayout>